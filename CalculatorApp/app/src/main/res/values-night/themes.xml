<resources>
    <!-- Base application theme (Dark). -->
    <style name="Theme.CalculatorApp" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accentBlue</item>
        <item name="colorPrimaryVariant">@color/accentBlueLight</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/darkBackground</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Background color. -->
        <item name="android:windowBackground">@color/darkBackground</item>
    </style>

    <!-- Display Screen Style -->
    <style name="CalcScreen" parent="">
        <item name="android:background">@color/darkCardBackground</item>
        <item name="android:textColor">@color/darkTextPrimary</item>
    </style>

    <!-- Normal Number Button Style -->
    <style name="CalcButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">@color/darkButtonBackground</item>
        <item name="android:textColor">@color/darkTextPrimary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Basic Operator Button Style (+, -, *, /) -->
    <style name="CalcButton.Operator">
        <item name="backgroundTint">@color/accentOrange</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Scientific Operator Button Style (sin, cos, log, sqrt) -->
    <style name="CalcButton.Scientific">
        <item name="backgroundTint">@color/darkButtonBackground</item>
        <item name="android:textColor">@color/accentBlueLight</item>
    </style>

    <!-- Equal Button Style -->
    <style name="CalcButton.Equal">
        <item name="backgroundTint">@color/accentBlue</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Clear / Delete Button Style -->
    <style name="CalcButton.Action">
        <item name="backgroundTint">@color/darkButtonBackground</item>
        <item name="android:textColor">@color/accentRed</item>
    </style>
</resources>
